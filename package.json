{
  "name": "hoard",
  "version": "0.1.0",
  "description": "Your personal digital hoard — links, notes and images. All yours, all local.",
  "main": "out/main/index.js",
  "author": "David Bonilla",
  "scripts": {
    "dev": "node dev.mjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "copy-wasm": "node -e \"const fs=require('fs');fs.copyFileSync('node_modules/sql.js/dist/sql-wasm.wasm','resources/sql-wasm.wasm')\""
  },
  "dependencies": {
    "react-masonry-css": "^1.0.16",
    "react-syntax-highlighter": "^16.1.1",
    "sql.js": "^1.10.3",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "clsx": "^2.1.0",
    "electron": "^29.1.1",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "jimp": "^0.22.10",
    "lucide-react": "^0.323.0",
    "postcss": "^8.4.33",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "zustand": "^4.5.0"
  },
  "build": {
    "appId": "com.hoard.app",
    "productName": "Hoard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    }
  }
}
