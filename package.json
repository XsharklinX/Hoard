{
  "name": "hoard",
  "version": "3.0.0",
  "type": "module",
  "description": "Your personal digital hoard — links, notes and images. All yours, all local.",
  "main": "out/main/index.js",
  "author": "David Bonilla",
  "scripts": {
    "dev": "node dev.mjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "pretest": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "posttest": "electron-rebuild -f -w better-sqlite3",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "@tanstack/react-virtual": "^3.13.24",
    "@tiptap/extension-character-count": "^3.23.1",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-mention": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-table": "^3.23.1",
    "@tiptap/extension-table-cell": "^3.23.1",
    "@tiptap/extension-table-header": "^3.23.1",
    "@tiptap/extension-table-row": "^3.23.1",
    "@tiptap/extension-task-item": "^3.22.5",
    "@tiptap/extension-task-list": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@tiptap/suggestion": "^3.22.5",
    "@types/dompurify": "^3.0.5",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.9.0",
    "cmdk": "^1.1.1",
    "dompurify": "^3.4.2",
    "electron-updater": "^6.8.3",
    "react-masonry-css": "^1.0.16",
    "react-syntax-highlighter": "^16.1.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.17",
    "clsx": "^2.1.0",
    "electron": "^29.1.1",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "jimp": "^0.22.10",
    "lucide-react": "^0.323.0",
    "postcss": "^8.4.33",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^4.1.5",
    "zustand": "^4.5.0"
  },
  "build": {
    "appId": "com.hoard.app",
    "productName": "Hoard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    }
  }
}
