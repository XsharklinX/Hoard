{
  "manifest_version": 3,
  "name": "Save to Hoard",
  "version": "1.3",
  "description": "Save links, images and videos directly to your local Hoard vault. Right-click anything on any page.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "omnibox",
    "scripting"
  ],
  "omnibox": { "keyword": "hoard" },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Open Hoard popup"
    },
    "quick-capture": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Quick capture current page to Hoard (no popup)"
    }
  },
  "action": {
    "default_title": "Hoard (Alt+S)",
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "http://127.0.0.1:43210/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    { "resources": ["content.js", "icon.png"], "matches": ["<all_urls>"] }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
