{
  "manifest_version": 3,
  "name": "Save to Hoard",
  "version": "1.2",
  "description": "Save links, images and videos directly to your local Hoard vault. Right-click anything on any page.",
  "browser_specific_settings": {
    "gecko": {
      "id": "hoard@local",
      "strict_min_version": "121.0"
    }
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage"
  ],
  "action": {
    "default_title": "Hoard",
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "http://127.0.0.1:43210/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
