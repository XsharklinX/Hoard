{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.2",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "hoard@local",
      "strict_min_version": "121.0"
    }
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "alarms",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Hoard",
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "http://127.0.0.1:43210/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
